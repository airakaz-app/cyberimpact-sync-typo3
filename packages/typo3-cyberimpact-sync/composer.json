{
  "name": "cyberimpact/cyberimpact-sync",
  "description": "TYPO3 extension for Cyberimpact contact synchronization",
  "type": "typo3-cms-extension",
  "license": "proprietary",
  "require": {
     "typo3/cms-core": "^12.4 || ^13.4 || ^14.0",
    "typo3/cms-backend": "^12.4 || ^13.4 || ^14.0",
    "typo3/cms-scheduler": "^12.4 || ^13.4 || ^14.0"
  },
  "autoload": {
    "psr-4": {
      "Cyberimpact\\CyberimpactSync\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "cyberimpact_sync"
    }
  }
}
